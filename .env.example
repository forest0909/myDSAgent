# 模型配置模板，复制为 .env 后填入实际值
# 支持所有 OpenAI 兼容 API（Ollama / DeepSeek / OpenAI / 等）

# ---- Ollama 本地（默认）----
VITE_MODEL_NAME=qwen2.5:latest
VITE_MODEL_API_KEY=ollama
VITE_MODEL_BASE_URL=http://localhost:11434

# ---- DeepSeek ----
# VITE_MODEL_NAME=deepseek-v4-flash
# VITE_MODEL_API_KEY=sk-你的key
# VITE_MODEL_BASE_URL=https://api.deepseek.com

# ---- OpenAI ----
# VITE_MODEL_NAME=gpt-4o
# VITE_MODEL_API_KEY=sk-你的key
# VITE_MODEL_BASE_URL=https://api.openai.com
